{
	"name": "sayuna",
	"version": "2.6.0",
	"description": "Easily extensible and customizable all-in-one Discord bot. Moderation, music & fun!",
	"author": "Witold Zawada",
	"private": true,
	"license": "MIT",
	"type": "module",
	"main": "build/main.js",
	"engines": {
		"node": ">=24.x.x",
		"pnpm": ">=10.x.x"
	},
	"scripts": {
		"start": "node --env-file .env build/main.js",
		"start:prod": "NODE_ENV='production' pm2 start build/main.js --name sayuna",
		"dev": "NODE_ENV='development' node --env-file .env --watch --import tsx src/main.ts",
		"build": "tsc",
		"check": "pnpm biome check --fix ./src"
	},
	"dependencies": {
		"@discordjs/voice": "^0.19.2",
		"@discordx/importer": "^1.3.3",
		"@discordx/pagination": "^4.4.1",
		"@discordx/utilities": "^8.0.0",
		"@distube/deezer": "^2.0.1",
		"@distube/direct-link": "^1.0.1",
		"@distube/soundcloud": "^2.0.4",
		"@distube/spotify": "^2.0.2",
		"@distube/youtube": "^1.0.4",
		"@noble/ciphers": "^2.2.0",
		"@snazzah/davey": "^0.1.12",
		"discord.js": "^14.27.0",
		"discordx": "^11.13.3",
		"distube": "^5.2.3",
		"moment": "^2.30.1",
		"opusscript": "^0.1.1",
		"reflect-metadata": "^0.2.2",
		"winston": "^3.19.0",
		"winston-transport": "^4.9.0",
		"youtubei.js": "^17.2.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.4",
		"@swc/core": "^1.15.43",
		"@types/node": "^26.1.1",
		"tsx": "^4.23.1",
		"typescript": "^7.0.2"
	},
	"volta": {
		"node": "24.18.0"
	}
}
